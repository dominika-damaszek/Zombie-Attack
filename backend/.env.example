# Copy this file to .env and fill in your values.
# Never commit .env to git – it contains secrets.

# ── Database (Neon only) ──────────────────────────────────────────────────────
# Paste the connection string from your Neon dashboard (must match database.py).
# Example: postgresql://user:password@ep-xyz.us-east-1.aws.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@ep-your-neon-host.neon.tech/dbname?sslmode=require

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Change this to a long, random string before deploying to production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ZOMBIEWARE_SECRET_KEY
